# =============================================================
# Reservation Agent — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# --- Twilio (required from M2+) ---
# Sign up: https://twilio.com/try-twilio
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1YOUR_TWILIO_NUMBER

# --- OpenAI (required from M3+) ---
# Sign up: https://platform.openai.com
OPENAI_API_KEY=sk-your-openai-key

# --- Redis (required for production) ---
# Install: sudo apt install redis-server  OR  docker run -p 6379:6379 redis
REDIS_URL=redis://localhost:6379/0

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
PUBLIC_HOST=your-domain.ngrok-free.app
USE_TLS=true

# --- Database ---
SQLITE_DB_PATH=data/reservations.db

# --- Call Behavior ---
MAX_CALL_RETRIES=3
RETRY_DELAY_SECONDS=60
CALL_DURATION_LIMIT_SECONDS=300
RING_TIMEOUT_SECONDS=30

# --- Silence Detection ---
SILENCE_THRESHOLD_MS=700
HOLD_TIMEOUT_SECONDS=30
MAX_SILENCE_SECONDS=120

# --- WebSocket Auth ---
WS_TOKEN_TTL_SECONDS=60

# --- Rate Limits ---
RATE_LIMIT_RESERVATIONS=5/minute
RATE_LIMIT_QUERIES=30/minute
RATE_LIMIT_GLOBAL=100/minute

# --- Stale State Cleanup ---
STALE_CALLING_TIMEOUT_MINUTES=10
STALE_ALT_PROPOSED_TIMEOUT_HOURS=24
